# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=tu_api_key_aqui
EVOLUTION_INSTANCE=tu_instancia_aqui

# Puerto del servidor webhook
BOT_PORT=3020

# URL del backend
BACKEND_URL=http://localhost:3000

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_password
DB_NAME=gestion_aulas
DB_SSL=false

# Groq API — Transcripción de notas de voz (OPCIONAL pero recomendado)
# Obtén tu clave GRATIS en: https://console.groq.com → API Keys
# La clave empieza con: gsk_...
# Sin esta clave, el bot no podrá entender notas de voz.
VOICE_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
