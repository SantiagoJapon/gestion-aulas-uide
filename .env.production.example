# ============================================
# Variables de Produccion - Gestion Aulas UIDE
# ============================================
# Copiar este archivo como .env.production y llenar los valores
# cp .env.production.example .env.production
# ============================================

# --- Base de Datos ---
DB_USER=postgres
DB_PASSWORD=CAMBIAR_password_seguro_aqui_123!
DB_NAME=gestion_aulas

# --- Redis ---
REDIS_PASSWORD=CAMBIAR_redis_password_456!

# --- Backend ---
JWT_SECRET=CAMBIAR_generar_con_openssl_rand_base64_32
JWT_EXPIRES_IN=24h
FRONTEND_URL=http://TU_IP_O_DOMINIO
ALLOWED_ORIGINS=http://TU_IP_O_DOMINIO,https://tudominio.com

# --- n8n (solo acceso interno) ---
N8N_USER=admin
N8N_PASSWORD=CAMBIAR_n8n_password_seguro

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=TU_TOKEN_DE_BOTFATHER

# --- Voz (Groq Whisper - opcional) ---
VOICE_API_KEY=

# --- OpenAI (opcional, para extraccion de estudiantes) ---
OPENAI_API_KEY=

# --- Anthropic (opcional) ---
ANTHROPIC_API_KEY=
AI_PROVIDER=anthropic

# --- Dominio (para SSL con Let's Encrypt) ---
# Si usas IP directa, dejar vacio
DOMAIN=

# ============================================
# CONFIGURACIÓN SMTP (Envío de Emails)
# ============================================
# Configuración para enviar correos institucionales
# Ejemplo con Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu_email@gmail.com
# SMTP_PASS=tu_app_password
# SMTP_FROM="Sistema Aulas UIDE" <no-reply@uide.edu.ec>

# Ejemplo con Office 365:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu_email@uide.edu.ec
# SMTP_PASS=tu_password
# SMTP_FROM="Sistema Aulas UIDE" <tu_email@uide.edu.ec>

# Ejemplo con SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxx
# SMTP_FROM="Sistema Aulas UIDE" <no-reply@tu_dominio.com>

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Sistema Gestión Aulas UIDE" <no-reply@uide.edu.ec>
